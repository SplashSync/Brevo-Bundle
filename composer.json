{
    "name":                 "splash/brevo",
    "description":          "Splash Brevo (Ex SendInBlue) API Connector (Embedded)",

    "type":                 "symfony-bundle",
    "license":              "MIT",
    "minimum-stability":    "dev",
    "prefer-stable":        true,

    "authors": [
        {
            "name":"Splash Sync",
            "email":"contact@splashsync.com"
        },
        {
            "name": "BadPixxel",
            "email": "eshop.bpaquier@gmail.com"
        }
    ],

    "autoload": {
        "psr-4": { 
            "Splash\\Connectors\\Brevo\\":             "src/"
        }
    },
    
    "autoload-dev": {
        "psr-4": {
            "Splash\\Connectors\\Brevo\\Test\\":       "tests/"
        }        
    },
    
    
    "require": {
        "php":                                          "^8.3",
        "ext-json":                                     "*",
        "splash/php-bundle":                            "^3.0",
        "splash/openapi":                               "^3.0",
        "giggsey/libphonenumber-for-php-lite":          "^9.0"
    },

    "require-dev": {
        "badpixxel/php-sdk":                            "^3.0",
        "splash/toolkit":                               "^3.0",
        "splash/bridge-builder":                        "^3.0",

        "api-platform/core":                            "*"
    },

    "scripts": {
        "auto-scripts": [
            "php bin/console cache:clear --no-debug",
            "php bin/console importmap:install",
            "php bin/console assets:install --relative",
            "php bin/console doctrine:schema:update --force --complete --no-interaction --no-debug",
            "find var/cache/dev/*.xml  -not -name \"testContainer.xml\" | while read -r i; do cp \"$i\" var/cache/dev/testContainer.xml; done"
        ],
        "post-install-cmd": [
            "@auto-scripts",
            "php bin/console sonata:user:create Toolkit toolkit@splashsync.com toolkit --super-admin || exit 0"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "post-build-cmd": [
            "php bin/console cache:clear --env=prod --no-debug",
            "php bin/console assets:install"
        ]
    },
    "archive": {
        "exclude": ["/config", "/bin", "/ci", "/docs", "/dist", "/tests"]
    },

    "config": {
        "allow-plugins": {
            "phpro/grumphp":            true,
            "symfony/runtime":          true,
            "phpro/grumphp-shim":       true,
            "php-http/discovery":       true
        }
    },
    "extra": {
        "public-dir": "tests/public",
        "splash-bridge": {
            "name":             "sendinblue",
            "version":          "3.0",
            "php-version":      "8.3.30",
            "output":           "bridges/sendinblue-3.0.phar",
            "connector":        "Splash\\Connectors\\Brevo\\Connectors\\BrevoConnector",
            "sources": {
                "connector/Brevo":                      "src",
                "config":                               "stubs/config/"
            },
            "require": {
                "ext-json":                             "*",
                "splash/php-bundle":                    "^3.0",
                "splash/scopes":                        "^1.0",
                "splash/openapi":                       "^3.0",
                "giggsey/libphonenumber-for-php-lite":  "^9.0",
                "symfony/console":                      "^7.4",
                "symfony/http-kernel":                  "^7.4",
                "symfony/framework-bundle":             "^7.4",
                "symfony/twig-bundle":                  "^7.4",
                "symfony/translation":                  "^7.4",
                "symfony/routing":                      "^7.4",
                "symfony/form":                         "^7.4",
                "symfony/yaml":                         "^7.4",
                "symfony/intl":                         "^7.4",
                "symfony/runtime":                      "^7.4",
                "symfony/validator":                    "^7.4",
                "symfony/rate-limiter":                 "^7.4",
                "symfony/monolog-bundle":               "*",
                "monolog/monolog":                      "^3.0",
                "doctrine/collections":                 "^2.0"
            }
        }
    }
}
